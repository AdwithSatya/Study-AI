# NoteAI Environment Variables Example Configuration
# Copy this file to '.env' and fill in your values.

# 1. Groq LLM API Key (Get one from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# 2. Database Connection URL (Postgres database connection string)
# Example: postgresql+asyncpg://user:password@host:port/dbname?ssl=require
DATABASE_URL=postgresql+asyncpg://your_db_user:your_db_password@your_db_host:your_db_port/your_db_name

# 3. JWT Security Settings
# SECRET_KEY: signs access tokens. Generate a secure random string.
# REFRESH_SECRET_KEY: signs refresh tokens — MUST be different from SECRET_KEY.
# Example command: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secure_random_hex_secret_key_here
REFRESH_SECRET_KEY=your_secure_random_hex_refresh_secret_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# 4. Chroma Cloud Configuration (Get these details from your Chroma Cloud dashboard)
CHROMA_API_KEY=your_chroma_api_key_here
CHROMA_TENANT=your_chroma_tenant_id_here
CHROMA_DATABASE=your_chroma_database_name_here

# 5. Hugging Face Inference API Token (for cloud-based embeddings — no local model)
# Get a free token at https://huggingface.co/settings/tokens (Read access is enough)
# This replaces local sentence-transformers / fastembed to stay under Render's 525 MB limit.
HF_API_TOKEN=your_huggingface_api_token_here

# 6. (Optional) Embedding model served by HuggingFace Inference API
# Default: sentence-transformers/all-MiniLM-L6-v2
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
